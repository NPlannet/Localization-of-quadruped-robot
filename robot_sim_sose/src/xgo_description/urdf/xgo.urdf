<?xml version="1.0"?>
<robot name="xgo_simple">
  
  <link name="base_link">

    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.15 0.10"/>
      </geometry>

      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.25 0.15 0.10"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0"
               izz="0.01"/>
    </inertial>

  </link>

  <link name="front_left_wheel">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>

  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.08 0.075 0.02" rpy="1.5707 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>



  <link name="front_right_wheel">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>

  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.08 -0.075 0.02" rpy="1.5707 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>



  <link name="rear_left_wheel">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>

  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.08 0.075 0.02" rpy="1.5707 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>



  <link name="rear_right_wheel">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>

  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.08 -0.075 0.02" rpy="1.5707 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="lidar_link">

  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.2"/>
    <inertia ixx="0.001" iyy="0.001" izz="0.001"
             ixy="0" ixz="0" iyz="0"/>
  </inertial>

  <!-- kleiner "Kuchen" -->
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>

    <geometry>
      <cylinder radius="0.04" length="0.03"/>
    </geometry>

    <material name="black">
      <color rgba="0.1 0.1 0.1 1"/>
    </material>
  </visual>

  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>

    <geometry>
      <cylinder radius="0.04" length="0.03"/>
    </geometry>
  </collision>

</link>


<!-- ===================== -->
<!-- LIDAR JOINT           -->
<!-- ===================== -->

<joint name="lidar_joint" type="fixed">

  <parent link="base_link"/>
  <child link="lidar_link"/>

  <!-- oben auf dem Roboter -->
  <origin xyz="0 0 0.12" rpy="0 0 0"/>

</joint>


<!-- ===================== -->
<!-- GAZEBO LIDAR SENSOR   -->
<!-- ===================== -->

<gazebo reference="lidar_link">

  <sensor name="gpu_lidar" type="gpu_lidar">

    <pose>0 0 0 0 0 0</pose>
    <!--<pose relative_to='lidar_frame'>0 0 0 0 0 0</pose>-->
    <topic>lidar</topic>

    <update_rate>1</update_rate>

    <ray>

      <scan>

        <horizontal>
          <samples>5</samples>
          <resolution>1</resolution>
          <min_angle>-1.396263</min_angle>
          <max_angle>1.396263</max_angle>
        </horizontal>

        <vertical>
          <samples>1</samples>
          <resolution>0.01</resolution>
          <min_angle>0</min_angle>
          <max_angle>0</max_angle>
        </vertical>

      </scan>

      <range>
        <min>0.08</min>
        <max>10.0</max>
        <resolution>0.01</resolution>
      </range>

    </ray>

    <always_on>true</always_on>
    <visualize>true</visualize>

  </sensor>

</gazebo>

<link name="camera_link">

  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.1"/>

    <inertia ixx="0.001" iyy="0.001" izz="0.001"
             ixy="0" ixz="0" iyz="0"/>
  </inertial>

  <!-- small camera box -->
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>

    <geometry>
      <box size="0.04 0.04 0.03"/>
    </geometry>

    <material name="black">
      <color rgba="0.1 0.1 0.1 1"/>
    </material>
  </visual>

  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>

    <geometry>
      <box size="0.04 0.04 0.03"/>
    </geometry>
  </collision>

</link>


<joint name="camera_joint" type="fixed">

  <parent link="base_link"/>
  <child link="camera_link"/>

  <!-- front-top of robot -->
  <origin xyz="0.14 0 0.10" rpy="0 0 0"/>

</joint>


<gazebo reference="camera_link">

  <sensor name="front_camera" type="camera">

    <pose>0 0 0 0 0 0</pose>

    <update_rate>1</update_rate>

    <topic>/camera/image_raw</topic>

    <camera>

      <horizontal_fov>1.57</horizontal_fov>

      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>

      <clip>
        <near>0.01</near>
        <far>100</far>
      </clip>

    </camera>

    <always_on>true</always_on>
    <visualize>true</visualize>

  </sensor>

</gazebo>

      
</robot>